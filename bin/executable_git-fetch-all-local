#!/bin/sh
# 現在 checkout 中のブランチを除く全ローカルブランチを
# `git fetch origin a:a b:b ...` でまとめて FF 更新する。
# FF できないブランチがあれば git がエラーで終了する。
set -eu

cur=$(git symbolic-ref --short HEAD 2>/dev/null || true)
refs=$(git for-each-ref --format='%(refname:short)' refs/heads/ \
  | grep -vx "$cur" \
  | awk '{print $1":"$1}')

if [ -z "$refs" ]; then
  echo "No local branches to update." >&2
  exit 0
fi

# shellcheck disable=SC2086
git fetch origin $refs
